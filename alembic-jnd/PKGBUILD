# Maintainer: Name <name@fai.com>

pkgname=alembic-jnd
pkgver=1.8.12.20260702
pkgrel=1
_ver_release="1.8.12"
_name_release="alembic-${_ver_release}"
pkgdesc="An open framework for storing and sharing scene data"
url="http://www.alembic.io/"
arch=('x86_64')
license=('BSD-3-Clause')
depends=('libgcc' 'libstdc++' 'imath'
)
makedepends=('cmake'
)
conflicts=('alembic' 'alembic-git')
provides=('alembic')
options=('!debug')
source=("alembic-${_ver_release}.tar.gz"
)
sha256sums=('b6d916c40446e8c502c84273092ab3d98f3f7f6094f8a2b8203d23e2f1d2a4a0'
)

build() {
  cd "${_name_release}"

  cmake \
    -Bbuild \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_CXX_FLAGS_RELEASE:STRING=-DNDEBUG \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_SKIP_RPATH=ON \
    -DUSE_TESTS=OFF
  sed -i "s/\-O3//g" $(find . -name flags.make)
  make -C build
}

package() {
  cd "${_name_release}"
  install -Dm644 LICENSE.txt "${pkgdir}"/usr/share/licenses/${pkgname}/LICENSE
  
  DESTDIR="${pkgdir}" make -C build install
}
